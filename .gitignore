# Git ignore for ASCENRIX workspace
# See https://git-scm.com/docs/gitignore

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
package-lock.json.lock

# Next.js / React build output
.next/
out/
.next/cache/
.build/
dist/

# Salesforce / SFDX
.sfdx/
.sf/
.localdevserver/
deploy-options.json
force-app/main/default/.sfdx/

# LWC
**/lwc/jsconfig.json

# Test coverage
coverage/

# ESLint and other caches
.eslintcache
.pmdCache
*.cache

# Logs
logs/
*.log
*.log.*

# Environment files
.env
.env.*

# Editor directories and files
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# macOS system files
.DS_Store
.AppleDouble
.LSOverride

# Windows system files
Thumbs.db
ehthumbs.db
[Dd]esktop.ini
$RECYCLE.BIN/

# Python virtual environments
**/__pycache__/
**/.venv/
**/venv/

# Misc
*.tmp
*.temp
*.bak
*.orig

# Optional: ignore build and dependency artifacts in workspace root
*.log

# Ignore generated local development files
*.local
